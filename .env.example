# Teleoscope environment variables
# Copy to .env: cp .env.example .env
# For local dev (teleoscope.ca), also: cp .env teleoscope.ca/.env.local

# --- MongoDB ---
MONGODB_PASSWORD=teleoscope_dev_password
MONGODB_URI=mongodb://teleoscope:teleoscope_dev_password@mongodb:27017/teleoscope?directConnection=true&serverSelectionTimeoutMS=2000&authSource=admin
MONGODB_REGISTRAR_URI=mongodb://teleoscope:teleoscope_dev_password@mongodb:27017/teleoscope?directConnection=true&serverSelectionTimeoutMS=2000&authSource=admin
MONGODB_DATABASE=teleoscope
MONGODB_USERNAME=teleoscope
MONGODB_HOST=mongodb
MONGODB_OPTIONS=directConnection=true&serverSelectionTimeoutMS=2000&authSource=admin

# --- RabbitMQ ---
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=teleoscope-dispatch
RABBITMQ_DISPATCH_QUEUE=teleoscope-dispatch
RABBITMQ_TASK_QUEUE=teleoscope-tasks
RABBITMQ_VECTORIZE_QUEUE=teleoscope-vectorize
RABBITMQ_UPLOAD_VECTOR_QUEUE=teleoscope-upload-vector

# --- Milvus ---
# Docker image: see docker-compose.yml (e.g. milvusdb/milvus v2.6.x). Python: pymilvus 2.6.x in backend/requirements.txt.
# Endpoint resolution (single ruleset: backend/milvus_uri_resolve.py, used by embeddings + scripts):
#   MILVUS_URI if set, else http://MILVUS_HOST:MIVLUS_PORT (typo intentional) or MILVUS_PORT or 19530.
#
# MILVUS_DOCKER_URI (optional): used only by docker-compose variable substitution. Compose sets worker/uploader
# MILVUS_URI from ${MILVUS_DOCKER_URI:-http://milvus:19530} so containers talk to in-network Milvus by default.
# Set MILVUS_DOCKER_URI to your Zilliz https endpoint when using managed Milvus with Docker workers. Leave unset
# for local compose (defaults to http://milvus:19530).
# Do NOT put MILVUS_URI=http://localhost:... in .env when using Docker workers — localhost inside a container is
# the container itself, not the host. For host-run seed/status scripts, export MILVUS_URI in the shell only
# (e.g. scripts/milvus_docker_uri.sh), or rely on MILVUS_HOST + mapped port on the host.
MILVUS_HOST=milvus
# Milvus *database* for MilvusClient multi-DB (Zilliz / newer servers). Collection name is usually still teleoscope.
MILVUS_DBNAME=teleoscope
# Optional: override collection name for tools (defaults to MILVUS_COLLECTION or MILVUS_DBNAME or teleoscope).
# MILVUS_COLLECTION=teleoscope
# Optional: named DB only; if unset, export/import fall back like embeddings.connect().
# MILVUS_DATABASE=
# Self-hosted http:// without token connects to Milvus default DB first (avoids RPC error spam).
# Set to force db_name=MILVUS_DBNAME on connect (unusual self-hosted multi-DB over HTTP).
# MILVUS_FORCE_DB_NAME_ON_CONNECT=1
# Host port for Milvus gRPC (maps container 19530). Matches docker-compose default; host seed/status → http://localhost:19530.
# Set MILVUS_HOST_PORT=0 only if 19530 is taken (random host port; milvus_docker_uri.sh uses docker compose port).
MILVUS_HOST_PORT=19530
# Zilliz Cloud / remote Milvus (overrides host:port when set — see docs/zilliz-migration.md):
# MILVUS_URI=https://in01-xxxxxxxx.vectordb.zillizcloud.com:19536
# Milvus auth (enforced in embeddings.connect):
# - HTTPS / Zilliz: require MILVUS_TOKEN or MILVUS_USERNAME+MILVUS_PASSWORD (or MILVUS_ALLOW_ANONYMOUS_HTTPS=1).
# - HTTP: anonymous allowed only for localhost / milvus / host.docker.internal / … or MILVUS_ALLOW_ANONYMOUS=1
#   or MILVUS_ANONYMOUS_HTTP_HOSTS=host1,host2. Remote http://IP without creds is refused by default.
# - MILVUS_REQUIRE_AUTH=1 forces credentials even on allowlisted HTTP hosts.
# MILVUS_TOKEN=your-api-key-or-user-colon-password
# MILVUS_USERNAME=db_admin
# MILVUS_PASSWORD=your-zilliz-db-admin-password
# MIVLUS_PORT is intentionally spelled this way (legacy env name).

# --- App ---
NODE_ENV=production
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-in-production
TELEOSCOPE_BASE_URL=http://localhost:3000
UPLOAD_DIR=/tmp/teleoscope/uploads
DOWNLOAD_DIR=/tmp/teleoscope/downloads

# --- Public demo workspace corpus ---
# /demo sends visitors to an anonymous workspace that uses this corpus (search, docs, vector ranking).
# Optional: the app auto-discovers the demo corpus by finding the workspace with label "Demo corpus" in Mongo
# (same label as scripts/seed-demo-corpus.py). Set this to avoid a one-time DB lookup on first demo request.
# One-click demo writes it when the seed script prints a workspace ID.
# DEMO_CORPUS_WORKSPACE_ID=<workspace_oid>

# --- Stripe (optional - signup works without these) ---
# STRIPE_TEST_SECRET_KEY=sk_test_...
# STRIPE_CLIENT_SECRET=sk_live_...
# STRIPE_TESTING_ENDPOINT_SECRET=whsec_...

# --- Google OAuth (optional) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Loops email service (optional) ---
# LOOPS_API_KEY=

# --- Mailchimp (optional) ---
# NEXT_MAILCHIMP_URL=

# --- EC2 auto-scaler (monitor.py — enabled in docker-compose.prod.yml) ---
# GPU EC2 instance ID for the vectorizer (required when using docker-compose.prod.yml).
# monitor.py starts this instance when the vectorize queue is non-empty and stops
# it after VECTORIZER_IDLE_STOP_MINUTES of an empty queue.
# EC2_VECTORIZE_INSTANCE=i-0abc1234567890def
#
# Optional: self-hosted vector DB instance to keep alive (omit when using Zilliz).
# EC2_VECTORDB_INSTANCE=i-0def9876543210abc
#
# AWS region for boto3 (default: ca-central-1).
# AWS_REGION=ca-central-1
#
# Seconds between queue polls (default: 10).
# MONITOR_CHECK_INTERVAL=10
#
# Minutes of empty queue before stopping the GPU instance (default: 10).
# VECTORIZER_IDLE_STOP_MINUTES=10
#
# AWS credentials — prefer an IAM instance role (no keys needed).
# Only set these if not using an instance role:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Vectorizer (activity-gated embedding worker) ---
# Docker Compose sets VECTORIZER_CONTROL_URL on the app to http://vectorizer:8765 by default.
# The UI pings /api/workers/vectorizer-activity while someone is in a workspace; that proxies
# POST /activity on the vectorizer so the model loads and the Rabbit consumer runs. After
# VECTORIZER_IDLE_SECONDS (default 300) with no pings and no in-flight vectorization, the
# consumer stops and the model unloads.
# VECTORIZER_CONTROL_URL=http://vectorizer:8765
# VECTORIZER_CONTROL_TOKEN=
# VECTORIZER_IDLE_SECONDS=300
# VECTORIZER_CONTROL_HOST=0.0.0.0
# VECTORIZER_CONTROL_PORT=8765
# Keep consumer + model loaded from startup (no HTTP control server). Use for CI or unattended stacks.
# VECTORIZER_ALWAYS_ON=1
