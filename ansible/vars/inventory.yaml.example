# Ansible inventory
#
# site.yaml builds a dynamic in-memory inventory automatically from AWS during
# provisioning — you do NOT need to edit this file when running site.yaml.
#
# Edit this file for standalone playbooks (deploy-update.yaml, deploy-main.yaml,
# etc.) after infrastructure is already provisioned. Replace IPs with the values
# from ansible/vars/infra-outputs.yaml (written by provision-aws.yaml / site.yaml).
#
# Run: ansible-playbook -i ansible/vars/inventory.yaml ansible/deploy-update.yaml

all:
  children:
    main:
      hosts:
        teleoscope-main:
          ansible_host: 1.2.3.4          # Elastic IP from infra-outputs.yaml
          ansible_user: ubuntu
          ansible_ssh_private_key_file: ~/.ssh/my-teleoscope-key.pem

    vectorizer:
      hosts:
        teleoscope-vectorizer:
          ansible_host: 5.6.7.8          # GPU EC2 public IP from infra-outputs.yaml
          ansible_user: ubuntu
          ansible_ssh_private_key_file: ~/.ssh/my-teleoscope-key.pem
