# Ansible variables — copy to vars.yaml and fill in your values.
# Do NOT commit vars.yaml (it is gitignored).
#
# Used by: ansible/site.yaml (full deploy) and individual playbooks.
#
# Security tip: encrypt vars.yaml at rest with Ansible Vault:
#   ansible-vault encrypt ansible/vars/vars.yaml
#   ansible-vault edit ansible/vars/vars.yaml
#   # Then add --ask-vault-pass to all ansible-playbook commands, or:
#   echo "your-vault-password" > ~/.teleoscope-vault-pass && chmod 600 ~/.teleoscope-vault-pass
#   # And set in ansible.cfg: vault_password_file = ~/.teleoscope-vault-pass

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
ansible_user: ubuntu
remote_prefix: /home

# SSH private key on your local machine (the key pair registered in AWS).
ssh_private_key_file: ~/.ssh/my-teleoscope-key.pem

# Restrict SSH access to your IP for better security: x.x.x.x/32
# Leave as 0.0.0.0/0 only if you accept open SSH (not recommended for prod).
ssh_allowed_cidr: 0.0.0.0/0

# -----------------------------------------------------------------------------
# Domain
# -----------------------------------------------------------------------------
teleoscope:
  ca: teleoscope.ca   # change if deploying to a different domain

# -----------------------------------------------------------------------------
# AWS — infrastructure provisioning (provision-aws.yaml / site.yaml)
# -----------------------------------------------------------------------------
aws_region: ca-central-1

# VPC CIDR for UFW rules allowing MongoDB/RabbitMQ from worker/GPU EC2s.
# Default AWS VPC is 172.31.0.0/16. Check: aws ec2 describe-vpcs --query 'Vpcs[0].CidrBlock'
vpc_cidr: 172.31.0.0/16

# EC2 key pair name as it appears in the AWS console (not the filename).
aws_key_pair: my-teleoscope-key

# Instance types:
#   main:    t3.large (8 GB)   — app, MongoDB, RabbitMQ, nginx, monitor.py (always on)
#   worker:  m6i.large (8 GB)  — Python workers: tasks, graph, dispatch, uploader, files (on-demand)
#   gpu:     g5.xlarge (GPU)   — BGE-M3 vectorizer (on-demand)
main_instance_type: t3.large
worker_instance_type: m6i.large
gpu_instance_type: g5.xlarge
# gpu_availability_zone: ca-central-1b   # uncomment if AWS reports InsufficientInstanceCapacity in default AZ

# EBS root volume sizes in GB.
main_volume_size: 80
worker_volume_size: 60
vectorizer_volume_size: 60

# Minutes of empty queues before stopping each on-demand instance.
worker_idle_stop_minutes: 10
vectorizer_idle_stop_minutes: 10

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
mongodb_admin_name: teleoscope_admin
mongodb_admin_password: change-me-admin-password
mongodb_dev_name: teleoscope
mongodb_dev_password: change-me-app-password
mongodb_database: teleoscope
mongodb_public_user: teleoscope
mongodb_public_password: change-me-app-password
mongodb_registrar_user: teleoscope
mongodb_registrar_password: change-me-app-password

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
rabbitmq_vhost: /
rabbitmq_admin_username: guest
rabbitmq_admin_password: guest
rabbitmq_dev_username: guest
rabbitmq_dev_password: guest
rabbitmq_public_user: guest
rabbitmq_public_password: guest
rabbitmq_task_queue: teleoscope-tasks
rabbitmq_dispatch_queue: teleoscope-dispatch

# -----------------------------------------------------------------------------
# Auth (NextAuth)
# -----------------------------------------------------------------------------
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
nextauth_secret: change-me-generate-a-random-secret

google_client_id: ""
google_client_secret: ""

# -----------------------------------------------------------------------------
# TLS / Let's Encrypt
# -----------------------------------------------------------------------------
certbot_email: admin@teleoscope.ca

# -----------------------------------------------------------------------------
# Milvus / Zilliz Cloud
# -----------------------------------------------------------------------------
# From your Zilliz console → Connect panel.
milvus_uri: "https://your-endpoint.zillizcloud.com:19530"
milvus_token: "your-zilliz-api-key"
milvus_dbname: teleoscope

# -----------------------------------------------------------------------------
# Vectorizer
# -----------------------------------------------------------------------------
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
vectorizer_control_token: change-me-vectorizer-token

# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
# loops_api_key: ""
# stripe_secret_key: ""

# -----------------------------------------------------------------------------
# Conda (legacy PM2 path only — not used by Docker/site.yaml)
# -----------------------------------------------------------------------------
conda_environment: teleoscope
conda_prefix: /usr/share/miniconda3
nodejs_version: "22"
ubuntu_version: jammy

# -----------------------------------------------------------------------------
# AWS credentials (legacy PM2 coordinator — not needed for Docker path)
# For site.yaml, set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY in your shell
# or use an AWS SSO profile (export AWS_PROFILE=my-profile).
# -----------------------------------------------------------------------------
aws_access_key: ""
aws_secret_key: ""
default_aws_region: ca-central-1
