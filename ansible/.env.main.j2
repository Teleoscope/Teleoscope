# .env — generated by Ansible for the main EC2 Docker Compose stack.
# Re-generate: ansible-playbook -i vars/inventory.yaml ansible/deploy-main.yaml
# Do not edit manually on the server; edit vars/vars.yaml and re-run.

# --- App ---
NODE_ENV=production
NEXTAUTH_URL=https://{{ teleoscope.ca }}
NEXTAUTH_SECRET={{ nextauth_secret }}
TELEOSCOPE_BASE_URL=https://{{ teleoscope.ca }}
UPLOAD_DIR=/tmp/teleoscope/uploads
DOWNLOAD_DIR=/tmp/teleoscope/downloads

# --- MongoDB ---
MONGODB_ADMIN_PASSWORD={{ mongodb_admin_password }}
MONGODB_USERNAME={{ mongodb_dev_name }}
MONGODB_PASSWORD={{ mongodb_dev_password }}

# --- RabbitMQ ---
RABBITMQ_USERNAME={{ rabbitmq_dev_username }}
RABBITMQ_PASSWORD={{ rabbitmq_dev_password }}
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_QUEUE={{ rabbitmq_dispatch_queue }}
RABBITMQ_DISPATCH_QUEUE={{ rabbitmq_dispatch_queue }}
RABBITMQ_TASK_QUEUE={{ rabbitmq_task_queue }}
RABBITMQ_VECTORIZE_QUEUE=teleoscope-vectorize
RABBITMQ_UPLOAD_VECTOR_QUEUE=teleoscope-upload-vector

# --- Milvus / Zilliz Cloud ---
# MILVUS_URI: used directly by host-side scripts (seed, monitor, health checks).
# MILVUS_DOCKER_URI: aliased to MILVUS_URI inside worker/graph containers via docker-compose.workers.yml.
MILVUS_URI={{ milvus_uri }}
MILVUS_DOCKER_URI={{ milvus_uri }}
MILVUS_TOKEN={{ milvus_token }}
MILVUS_USERNAME={{ milvus_username | default('') }}
MILVUS_PASSWORD={{ milvus_password | default('') }}
MILVUS_DBNAME={{ milvus_dbname | default('default') }}
MILVUS_COLLECTION={{ milvus_collection | default('reddit_posts') }}
MILVUS_VECTOR_FIELD={{ milvus_vector_field | default('dense') }}
MILVUS_VECTOR_INDEX={{ milvus_vector_index | default('dense_ivf_flat') }}
MILVUS_VECTOR_METRIC={{ milvus_vector_metric | default('COSINE') }}
MILVUS_VECTOR_DIM={{ milvus_vector_dim | default(1024) }}

# --- Vectorizer (activity-gated, model on GPU EC2) ---
VECTORIZER_CONTROL_URL=http://vectorizer:8765
VECTORIZER_CONTROL_TOKEN={{ vectorizer_control_token | default('') }}

# --- EC2 Auto-scaler (monitor.py) ---
EC2_WORKER_INSTANCE={{ ec2_worker_instance }}
EC2_VECTORIZE_INSTANCE={{ ec2_vectorize_instance }}
AWS_REGION={{ aws_region | default('ca-central-1') }}
WORKER_IDLE_STOP_MINUTES={{ worker_idle_stop_minutes | default(10) }}
VECTORIZER_IDLE_STOP_MINUTES={{ vectorizer_idle_stop_minutes | default(10) }}

{% if google_client_id %}
# --- Google OAuth ---
GOOGLE_CLIENT_ID={{ google_client_id }}
GOOGLE_CLIENT_SECRET={{ google_client_secret }}
{% endif %}
{% if loops_api_key is defined and loops_api_key %}
# --- Loops email ---
LOOPS_API_KEY={{ loops_api_key }}
{% endif %}
{% if stripe_secret_key is defined and stripe_secret_key %}
# --- Stripe ---
STRIPE_CLIENT_SECRET={{ stripe_secret_key }}
{% endif %}
